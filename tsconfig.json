{
  "compilerOptions": {
    "resolveJsonModule": true,
    "outDir": "./dist",
    "module": "CommonJS",
    "target": "es2024",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": [
        "*"
      ]
    }
  },
  "include": [
    "src",
    "test"
  ],
  "exclude": [],
  "types": [
    "node",
    "mocha"
  ]
}